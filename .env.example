# Cinema Game frontend — environment variables
#
# Copy this file to `.env.local` and fill in real values. `.env.local`
# is gitignored; do not commit it.

# ----------------------------------------------------------------------
# Public API URL
# ----------------------------------------------------------------------
# Used by the browser to call the FastAPI backend directly (e.g. fetch
# `${NEXT_PUBLIC_API_URL}/game/...`). Must be reachable from the user's
# browser, not only from the Next.js server.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----------------------------------------------------------------------
# Backend URL (server-side only)
# ----------------------------------------------------------------------
# Used server-side by the NextAuth `signIn` callback to call
# `${BACKEND_URL}/auth/check-beta`. In local development this is
# typically the same as NEXT_PUBLIC_API_URL; in production it can be an
# internal hostname that is not exposed to the browser.
BACKEND_URL=http://localhost:8000

# ----------------------------------------------------------------------
# Google OAuth
# ----------------------------------------------------------------------
# Create at https://console.cloud.google.com:
#   APIs & Services → OAuth consent screen → External
#   APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Authorized redirect URI for local development:
#   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----------------------------------------------------------------------
# Shared secrets (must match the backend's secrets/.env byte-for-byte)
# ----------------------------------------------------------------------
# Generate each with: openssl rand -base64 32
#
# NEXTAUTH_SECRET is the HS256 key used by NextAuth to sign the session
# JWT that the backend verifies via its `require_auth` dependency.
NEXTAUTH_SECRET=

# INTERNAL_SECRET is sent as the `x-internal-secret` header on
# server-to-server calls to the backend's /auth/check-beta endpoint,
# preventing browsers from invoking that endpoint directly.
INTERNAL_SECRET=
